QMainWindow, QWidget#centralwidget { background-color: #EBEBEB; }

QMenuBar {
    background-color: #2D6A4F; color: #FFFFFF;
    font: 11pt &quot;Segoe UI&quot;; padding: 2px 4px; border: none;
}
QMenuBar::item { padding: 4px 12px; border-radius: 4px; }
QMenuBar::item:selected { background-color: rgba(255,255,255,0.20); }
QMenu {
    background-color: #FFFFFF; color: #1A3C2A;
    border: 1px solid #C6F6D5; border-radius: 6px; font: 10pt &quot;Segoe UI&quot;;
}
QMenu::item { padding: 6px 20px; }
QMenu::item:selected { background-color: #2D6A4F; color: #FFFFFF; }
QMenu::separator { height: 1px; background-color: #C6F6D5; margin: 4px 10px; }

QToolBar {
    background-color: #2D6A4F; border: none; spacing: 4px; padding: 4px 8px;
}
QToolBar::separator { background-color: rgba(255,255,255,0.30); width: 1px; margin: 4px 6px; }
QToolBar QToolButton {
    background-color: transparent; color: #FFFFFF;
    border: 1px solid transparent; border-radius: 6px;
    padding: 5px 10px; font: 10pt &quot;Segoe UI&quot;;
}
QToolBar QToolButton:hover { background-color: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.35); }
QToolBar QToolButton:pressed { background-color: rgba(255,255,255,0.28); }

QStatusBar {
    background-color: #2D6A4F; color: #C6F6D5;
    font: 9pt &quot;Segoe UI&quot;; border-top: 1px solid #1F4D2C; padding: 2px 8px;
}
QStatusBar::item { border: none; }

QWidget#filesPanel, QWidget#tocPanel { background-color: #D9E9CF; }

QLabel#filesPanelHeader, QLabel#tocPanelHeader {
    background-color: #2D6A4F; color: #FFFFFF;
    font: bold 10pt &quot;Segoe UI&quot;; padding: 8px 12px;
}

QSplitter#leftSplitter::handle { background-color: #2D6A4F; }
QSplitter#leftSplitter::handle:hover { background-color: #52b788; }

QListWidget#filesList, QListWidget#tocList {
    background-color: #D9E9CF; color: #1A3C2A;
    border: none; font: 10pt &quot;Segoe UI&quot;; outline: none;
}
QListWidget#filesList::item, QListWidget#tocList::item {
    padding: 7px 12px; border-bottom: 1px solid #C2D9BA;
}
QListWidget#filesList::item:hover, QListWidget#tocList::item:hover {
    background-color: #C6E6D3; color: #0E3B21;
}
QListWidget#filesList::item:selected, QListWidget#tocList::item:selected {
    background-color: #2D6A4F; color: #FFFFFF; border-left: 3px solid #C6F6D5;
}

QScrollBar:vertical { background: #D9E9CF; width: 8px; margin: 0; border-radius: 4px; }
QScrollBar::handle:vertical { background: #7AB99A; border-radius: 4px; min-height: 28px; }
QScrollBar::handle:vertical:hover { background: #2D6A4F; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar:horizontal { background: #D9E9CF; height: 8px; border-radius: 4px; }
QScrollBar::handle:horizontal { background: #7AB99A; border-radius: 4px; min-width: 28px; }
QScrollBar::handle:horizontal:hover { background: #2D6A4F; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

QScrollArea#pageScrollArea { background-color: #D9E9CF; border: none; }
QWidget#scrollAreaContent { background-color: #D9E9CF; }

QFrame#paperPage1, QFrame#paperPage2 {
    background-color: #FFFFFF; border: none;
}

QLabel#companyName {
    color: #1A3C2A; font: bold 18pt &quot;Segoe UI&quot;;
}
QLabel#companyName2 {
    color: #1A3C2A; font: bold 14pt &quot;Segoe UI&quot;;
}
QLabel#companyTagline {
    color: #2D6A4F; font: 10pt &quot;Segoe UI&quot;;
}
QFrame#headerDivider, QFrame#headerDivider2 {
    background-color: #2D6A4F; max-height: 2px; border: none;
}
QLabel#docTitleLabel {
    color: #1A3C2A; font: bold 13pt &quot;Segoe UI&quot;; padding: 6px 0 2px 0;
}
QLabel#metaLabel { color: #4A7A5A; font: 9pt &quot;Segoe UI&quot;; }
QFrame#innerDivider { background-color: #C6F6D5; max-height: 1px; border: none; }
QLabel#sectionLabel {
    color: #2D6A4F; font: bold 11pt &quot;Segoe UI&quot;; padding: 10px 0 4px 0;
}
QLabel#continuedLabel2 {
    color: #2D6A4F; font: italic 9pt &quot;Segoe UI&quot;; padding: 4px 0 8px 0;
}
QLabel#notesLabel {
    color: #2D6A4F; font: bold 11pt &quot;Segoe UI&quot;; padding: 10px 0 4px 0;
}
QLabel#pageFooter1, QLabel#pageFooter2 {
    color: #7AB99A; font: 8pt &quot;Segoe UI&quot;;
    padding: 6px 0 0 0; border-top: 1px solid #C6F6D5;
}

QTableWidget#inventoryTable1,
QTableWidget#inventoryTable2 {
    background-color: #FFFFFF;
    alternate-background-color: #F4FBF6;
    gridline-color: #C6F6D5;
    color: #1A3C2A; font: 10pt &quot;Segoe UI&quot;;
    border: 1px solid #C6F6D5;
    selection-background-color: #D6EBDD;
    selection-color: #0E3B21;
}
QTableWidget#inventoryTable1::item,
QTableWidget#inventoryTable2::item {
    padding: 5px 8px; border: none;
}
QTableWidget#inventoryTable1::item:hover,
QTableWidget#inventoryTable2::item:hover {
    background-color: #EAF7EE;
}
QTableWidget#inventoryTable1 QHeaderView::section,
QTableWidget#inventoryTable2 QHeaderView::section {
    background-color: #2D6A4F; color: #FFFFFF;
    font: bold 10pt &quot;Segoe UI&quot;; padding: 7px 8px;
    border: none; border-right: 1px solid #3A7A5A;
    border-bottom: 2px solid #C6F6D5;
}
QTableWidget#inventoryTable1 QHeaderView::section:hover,
QTableWidget#inventoryTable2 QHeaderView::section:hover {
    background-color: #1F4D2C;
}

QTextEdit#notesEdit {
    background-color: #FAFFFE; color: #1A3C2A;
    font: 10pt &quot;Segoe UI&quot;; border: 1px solid #C6F6D5;
    border-radius: 4px; padding: 8px;
    selection-background-color: #D6EBDD;
}
QTextEdit#notesEdit:focus {
    border: 1px solid #2D6A4F; background-color: #EAF7EE;
}

