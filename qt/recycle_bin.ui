     <property name="styleSheet">
      <string notr="true">QPushButton {
    background-color: transparent;
    color: #7CFFB2;

    border: 1px solid #2F6B3F;   /* darker, visible green outline */
    border-radius: 10px;
    padding: 6px;
}

/* hover (subtle visible lift, no covering image) */
QPushButton:hover {
    background-color: rgba(47, 107, 63, 0.18);  /* soft green tint */
    border-color: #3A7F52;                      /* brighter border */
}

/* pressed (stronger feedback but still transparent) */
QPushButton:pressed {
    background-color: rgba(47, 107, 63, 0.28);
    border-color: #1F4D2C;                      /* darker press */
}</string>
