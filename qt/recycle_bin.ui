    <property name="styleSheet">
     <string notr="true">QTableWidget {
    background-color: #F6FBF8;          /* soft green-tinted white */
    border: 1px solid #D6E8DD;          /* subtle modern border */
    gridline-color: #E3EFE8;
    font: 13pt &quot;Segoe UI&quot;;

    selection-background-color: #4CAF70;
    selection-color: white;

    alternate-background-color: #EDF7F1;
}

/* cells */
QTableWidget::item {
    padding: 10px;
    border: none;
    color: #1F2D23;
}

/* hover (soft green highlight) */
QTableWidget::item:hover {
    background-color: #DFF3E6;
}

/* selected */
QTableWidget::item:selected {
    background-color: #4CAF70;
    color: white;
}

/* header (modern flat style) */
QHeaderView::section {
    background-color: #E4F1EA;
    color: #1F2D23;
    padding: 10px;
    border: none;
    font: 10pt &quot;Segoe UI&quot;;
    font-weight: 600;
}

/* row header hover (clickable feel) */
QHeaderView::section:vertical:hover {
    background-color: #CFE9D8;
}

/* row header pressed */
QHeaderView::section:vertical:pressed {
    background-color: #4CAF70;
    color: white;
}

/* corner */
QTableCornerButton::section {
    background-color: #E4F1EA;
    border: none;
}

/* Vertical ScrollBar */
QScrollBar:vertical {
    background: transparent;
    width: 16px;                     /* ⬅ bigger */
    margin: 6px 2px 6px 2px;
}

/* handle */
QScrollBar::handle:vertical {
    background: #CFE9D8;
    border-radius: 8px;
    min-height: 40px;               /* ⬅ bigger handle */
}

/* hover */
QScrollBar::handle:vertical:hover {
    background: #AFCFBB;
}

/* pressed */
QScrollBar::handle:vertical:pressed {
    background: #4CAF70;
}

/* remove arrows */
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
}

/* track */
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}

/* Horizontal ScrollBar */
QScrollBar:horizontal {
    background: transparent;
    height: 16px;                   /* ⬅ bigger */
    margin: 2px 6px 2px 6px;
}

/* handle */
QScrollBar::handle:horizontal {
    background: #CFE9D8;
    border-radius: 8px;
    min-width: 40px;                /* ⬅ bigger handle */
}

/* hover */
QScrollBar::handle:horizontal:hover {
    background: #AFCFBB;
}

/* pressed */
QScrollBar::handle:horizontal:pressed {
    background: #4CAF70;
}

/* remove arrows */
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    background: none;
}

/* track */
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: transparent;
}</string>
