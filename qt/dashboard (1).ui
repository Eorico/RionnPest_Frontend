   </property>
   <property name="styleSheet">
    <string notr="true">QToolBar {
    background-color: #2D6A4F;
    border: 1px solid #1F4D2C;
    padding: 8px;
    spacing: 6px;
    border-radius: 10px;
    margin: 6px;
}

/* Toolbar buttons */
QToolButton {
    background-color: transparent;
    color: white;
    border-radius: 6px;
    padding: 5px;
}

/* Hover effect */
QToolButton:hover {
    background-color: rgba(255, 255, 255, 0.15);
}

/* Click / pressed effect */
QToolButton:pressed {
    background-color: rgba(255, 255, 255, 0.25);
    padding-top: 7px;   /* slight “press down” illusion */
    padding-left: 6px;
}</string>
   </property>
