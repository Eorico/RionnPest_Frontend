       <string notr="true">QPushButton {
    background-color: #2F6B3F;
    color: #ffffff;
    border-style: solid;
    border-width: 2px;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-bottom-color: #cccccc;
    border-right-color: #cccccc;
    border-radius: 20px;
    padding: 12px 20px;
    font: bold 13pt &quot;Segoe UI&quot;;
    letter-spacing: 1px;
}

/* HOVER EFFECT */
QPushButton:hover {
    background-color: #285C36; /* slightly darker green */
    border-top-color: #E6E6E6;
    border-left-color: #E6E6E6;
    border-bottom-color: #B3B3B3;
    border-right-color: #B3B3B3;
}

/* CLICK / PRESSED EFFECT */
QPushButton:pressed {
    background-color: #0D2B1F; /* deep pressed green */
    border-top-color: #1A1A1A;  /* inverted depth */
    border-left-color: #1A1A1A;
    border-bottom-color: #4A4A4A;
    border-right-color: #4A4A4A;

    padding-top: 14px;   /* press down illusion */
    padding-left: 22px;
}</string>
