      <widget class="QLineEdit" name="searchDate">
       <property name="geometry">
        <rect>
         <x>20</x>
         <y>10</y>
         <width>241</width>
         <height>41</height>
        </rect>
       </property>
       <property name="styleSheet">
        <string notr="true">QLineEdit {
    background-color: #FFFFFF;
    border-radius: 20px;
    padding: 8px 16px 8px 36px;
    font: 11pt &quot;Segoe UI&quot;;
    color: #2F3A34;  /* slightly darker for better contrast */

    /* 3D GREEN BORDER */
    border-style: solid;
    border-width: 2px;
    border-top-color: #C6F6D5;
    border-left-color: #C6F6D5;
    border-bottom-color: #2D6A4F;
    border-right-color: #2D6A4F;
}

/* HOVER EFFECT (darker but still soft) */
QLineEdit:hover {
    background-color: #E3F2E9;   /* darker green tint */
    border-top-color: #BFE8CC;
    border-left-color: #BFE8CC;
    border-bottom-color: #1B4332; /* stronger shadow */
    border-right-color: #1B4332;

    color: #1F2E27; /* keep readable */
}

/* CLICKED / ACTIVE (FOCUS) EFFECT */
QLineEdit:focus {
    background-color: #D6EDE1;   /* noticeably darker active state */
    border-top-color: #A9D8BA;
    border-left-color: #A9D8BA;
    border-bottom-color: #0E3B21; /* deep pressed look */
    border-right-color: #0E3B21;

    color: #10261C; /* very readable dark green-black */
}</string>
       </property>
       <property name="placeholderText">
        <string>🔍  Search client or date...</string>
       </property>
