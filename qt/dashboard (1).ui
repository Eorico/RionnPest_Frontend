      <property name="styleSheet">
       <string notr="true">QLineEdit {
    background-color: #FFFFFF;
    border-radius: 10px;
    padding: 8px 16px 8px 36px;
    font: 11pt &quot;Segoe UI&quot;;
    color: #374151;

    /* 3D GREEN BORDER */
    border-style: solid;
    border-width: 2px;
    border-top-color: #C6F6D5;
    border-left-color: #C6F6D5;
    border-bottom-color: #2D6A4F;
    border-right-color: #2D6A4F;
}

/* HOVER EFFECT */
QLineEdit:hover {
    background-color: #F0FAF4;   /* soft green hover tint */
    border-top-color: #D7F2DE;
    border-left-color: #D7F2DE;
    border-bottom-color: #1B4332; /* darker shadow for depth */
    border-right-color: #1B4332;

    color: #2F3A34;
}

/* CLICKED / ACTIVE (FOCUS) EFFECT */
QLineEdit:focus {
    background-color: #E3F3EA;   /* stronger active tint */
    border-top-color: #BFE8CC;
    border-left-color: #BFE8CC;
    border-bottom-color: #0F3D24; /* deep pressed effect */
    border-right-color: #0F3D24;

    color: #10261C;
}</string>
