  <property name="styleSheet">
   <string notr="true">/* Background only for the stacked widget */



/* Make stacked widget pages transparent */
#stackedWidget &gt; QWidget {
    background: transparent;
}

/* Optional: Make labels transparent */
#stackedWidget QLabel {
    background: transparent;
}

/* Optional: Style input fields cleanly */
#stackedWidget QLineEdit {
    background-color: white;
    border-radius: 6px;
    padding: 5px;
}

/* Optional: Style buttons */
#stackedWidget QPushButton {
    background-color: #3498db;
    color: white;
    border-radius: 6px;
    padding: 6px;
}

/* Modern White Input Fields with Dark Hover (fixed for Qt) */
QLineEdit#usernameEdit, QLineEdit#passwordEdit {
    background-color: white;
    color: #333333;
    border: 1.5px solid #DCDCDC;
    border-radius: 10px;
    padding: 8px 35px 8px 10px; /* extra space for eye icon in password */
    font-size: 14px;
}

/* Hover Effect */
QLineEdit#usernameEdit:hover, QLineEdit#passwordEdit:hover {
    background-color: #F0F0F0;
    border: 1.5px solid #BFBFBF;
}

/* Focus */
QLineEdit#usernameEdit:focus, QLineEdit#passwordEdit:focus {
    border: 2px solid #4CAF50;
    background-color: white;
}

/* Placeholder text */
QLineEdit#usernameEdit::placeholder,
QLineEdit#passwordEdit::placeholder {
    color: #9E9E9E;
}</string>
  </property>
