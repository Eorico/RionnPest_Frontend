     <property name="styleSheet">
      <string notr="true">QPushButton {
    background-color: #28a745;
    color: white;
    border-style: solid;
    border-width: 2px;
    border-top-color: #5cd65c;      /* lighter top */
    border-left-color: #5cd65c;     /* lighter left */
    border-bottom-color: #1e7e34;   /* darker bottom */
    border-right-color: #1e7e34;    /* darker right */
    padding: 6px 12px;
    font: 15pt &quot;Segoe UI&quot;;
    border-radius: 5px;             /* optional: rounded corners */
}

QPushButton:hover {
    background-color: #218838;
    border-top-color: #66c266;
    border-left-color: #66c266;
    border-bottom-color: #1a6c2f;
    border-right-color: #1a6c2f;
}

QPushButton:pressed {
    background-color: #1e7e34;
    border-top-color: #1a6c2f;       /* invert for pressed */
    border-left-color: #1a6c2f;
    border-bottom-color: #66c266;
    border-right-color: #66c266;
}

QPushButton:disabled {
    background-color: #a8d5b7;
    color: #f0f0f0;
    border-top-color: #c0e0c2;
    border-left-color: #c0e0c2;
    border-bottom-color: #8ebf96;
    border-right-color: #8ebf96;
}</string>
