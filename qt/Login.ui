     <property name="styleSheet">
      <string notr="true">QLineEdit {
    background-color: white;                /* base white */
    color: #333333;
    border-style: solid;
    border-width: 2px;
    border-top-color: #FFFFFF;              /* lighter top */
    border-left-color: #FFFFFF;             /* lighter left */
    border-bottom-color: #BFBFBF;           /* darker bottom */
    border-right-color: #BFBFBF;            /* darker right */
    border-radius: 10px;                    
    padding: 8px 10px;
    font-size: 14px;
    transition: all 0.2s ease;              /* smooth hover/focus transitions */
}

/* Hover Effect — slightly darker background &amp; subtle border change */
QLineEdit:hover {
    background-color: #F0F0F0;
    border-top-color: #F5F5F5;
    border-left-color: #F5F5F5;
    border-bottom-color: #AAAAAA;
    border-right-color: #AAAAAA;
}

/* Focus Effect — bright green border with 3D depth */
QLineEdit:focus {
    border-top-color: #4CAF50;              /* brighter green top/left */
    border-left-color: #4CAF50;
    border-bottom-color: #388E3C;           /* darker green bottom/right */
    border-right-color: #388E3C;
    background-color: white;
}

/* Placeholder text */
QLineEdit::placeholder {
    color: #9E9E9E;
}</string>
