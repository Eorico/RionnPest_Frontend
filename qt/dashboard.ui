  <widget class="QMenuBar" name="menuBar">
   <property name="geometry">
    <rect>
     <x>0</x>
     <y>0</y>
     <width>1126</width>
     <height>48</height>
    </rect>
   </property>
   <property name="font">
    <font>
     <pointsize>12</pointsize>
    </font>
   </property>
   <property name="styleSheet">
    <string notr="true">QMenuBar {
    background-color: #2F6B3F;
    border-style: solid;
    border-width: 2px;
    border-top-color: #2F6B3F;
    border-left-color: #2F6B3F;
    border-bottom-color: #2F6B3F;
    border-right-color: #2F6B3F;
    padding: 6px 10px;
    color: white;
}

/* THIS is the important part */
QMenuBar::item {
    background-color: transparent;
    color: white;
    padding: 5px 10px;
}

/* hover effect */
QMenuBar::item:selected {
    background-color: #2F6B3F;   /* SAME as menu bar */
    color: white;
}

/* when pressed/open */
QMenuBar::item:pressed {
    background-color: #1e8f57;
}</string>
   </property>
   <widget class="QMenu" name="actions">
    <property name="cursor">
     <cursorShape>PointingHandCursor</cursorShape>
    </property>
    <property name="styleSheet">
     <string notr="true">QMenu {
    background-color: #2F6B3F;
    color: white;
    border: 2px solid #1e8f57;
    padding: 5px;
}

/* normal items */
QMenu::item {
    padding: 8px 25px;
    background-color: transparent;
}

/* hover effect */
QMenu::item:selected {
    background-color: #3d8f56;   /* lighter highlight */
    color: white;
}

/* pressed/clicked */
QMenu::item:pressed {
    background-color: #1e8f57;
}</string>
    </property>
    <property name="title">
