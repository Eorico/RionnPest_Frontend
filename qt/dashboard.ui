    <property name="styleSheet">
     <string notr="true">QLineEdit {
    background-color: #ffffff;        /* now white */
    border-style: solid;
    border-width: 2px;
    border-top-color: #ffffff;        /* light top */
    border-left-color: #ffffff;       /* light left */
    border-bottom-color: #aaaaaa;     /* dark bottom */
    border-right-color: #aaaaaa;      /* dark right */
    padding: 6px 10px;
    font: 11pt &quot;Segoe UI&quot;;
    color: #333333;
    border-radius: 4px;               /* optional rounded corners */
}

QLineEdit:focus {
    border-top-color: #28c770;        /* focus effect top */
    border-left-color: #28c770;
    border-bottom-color: #218c57;     /* focus effect bottom */
    border-right-color: #218c57;
    background-color: #ffffff;        /* stays white on focus */
}

QLineEdit:hover {
    border-top-color: #eeeeee;
    border-left-color: #eeeeee;
    border-bottom-color: #888888;
    border-right-color: #888888;
}

QLineEdit:disabled {
    background-color: #eeeeee;        /* muted gray when disabled */
    color: #aaaaaa;
    border-top-color: #f5f5f5;
    border-left-color: #f5f5f5;
    border-bottom-color: #cccccc;
    border-right-color: #cccccc;
}</string>
