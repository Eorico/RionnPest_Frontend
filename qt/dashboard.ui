     <string notr="true">QTableWidget {
    background-color: #ffffff;            /* white background */
    border-style: solid;
    border-width: 2px;
    border-top-color: #ffffff;            /* light top */
    border-left-color: #ffffff;           /* light left */
    border-bottom-color: #cccccc;         /* dark bottom */
    border-right-color: #cccccc;          /* dark right */
    gridline-color: #e6e6e6;
    font: 13pt &quot;Segoe UI&quot;;
    selection-background-color: #2ecc71;
    selection-color: white;
    alternate-background-color: #f9f9f9;
}

QTableWidget::item {
    padding: 6px;
    border-bottom: 1px solid #e6e6e6;
}

QTableWidget::item:selected {
    background-color: #2ecc71;   /* green when selected */
    color: white;
}

QTableWidget::item:hover {
    background-color: #f0f0f0;   /* darker on hover */
}

QHeaderView::section {
    background-color: #f3f3f3;
    color: #333333;
    padding: 6px;
    border-style: solid;
    border-width: 2px;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-bottom-color: #cccccc;
    border-right-color: #cccccc;
    font: 10pt &quot;Segoe UI&quot;;
}

QTableCornerButton::section {
    background-color: #f3f3f3;
    border-style: solid;
    border-width: 2px;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-bottom-color: #cccccc;
    border-right-color: #cccccc;
}</string>
