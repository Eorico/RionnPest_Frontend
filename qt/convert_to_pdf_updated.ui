  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: #F0FFF4; }

    /* ── Menu Bar ── */
    QMenuBar {
      background-color: #2D6A4F;
      border-bottom: 1px solid #1F4D2C;
      padding: 4px;
      font: 10.5pt &quot;Segoe UI&quot;;
      color: #FFFFFF;
    }
    QMenuBar::item {
      background-color: transparent;
      padding: 6px 12px;
      border-radius: 4px;
      color: #FFFFFF;
    }
    QMenuBar::item:selected {
      background-color: #3A7D5A;
    }
    QMenuBar::item:pressed {
      background-color: #1F4D2C;
    }
    QMenuBar::item:checked {
      background-color: #245C40;
    }

    /* ── Drop-down Menus ── */
    QMenu {
      background-color: #FFFFFF;
      border: 1px solid #C6F6D5;
      padding: 4px;
      font: 10pt &quot;Segoe UI&quot;;
    }
    QMenu::item {
      padding: 6px 24px;
      color: #1F3D2B;
    }
    QMenu::item:selected {
      background-color: #2D6A4F;
      color: #FFFFFF;
    }
    QMenu::item:disabled {
      color: #A0A0A0;
    }
    QMenu::separator {
      height: 1px;
      background: #C6F6D5;
      margin: 3px 0;
    }

    /* ── Ribbon / Toolbar ── */
    QToolBar {
      background-color: #F0FFF4;
      border-bottom: 2px solid #B7E4C7;
      padding: 4px 8px;
      spacing: 3px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    }
    QToolBar::separator {
      width: 1px;
      background-color: #B7E4C7;
      margin: 3px 5px;
    }
    QToolButton {
      background: transparent;
      border: 1px solid transparent;
      border-radius: 3px;
      padding: 3px 7px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
      color: #1F3D2B;
      min-width: 28px;
    }
    QToolButton:hover {
      background-color: #D8F3DC;
      border-color: #95D5B2;
    }
    QToolButton:pressed {
      background-color: #B7E4C7;
    }
    QToolButton:checked {
      background-color: #D8F3DC;
      border-color: #52B788;
      color: #1D6B2B;
      font-weight: bold;
    }

    /* ── Document Text Area ── */
    QTextEdit {
      background-color: #FFFFFF;
      border: none;
      font-family: &quot;Calibri&quot;, Georgia, serif;
      font-size: 15px;
      color: #111111;
      line-height: 1.8;
    }

    /* ── Status Bar ── */
    QStatusBar {
      background-color: #2D6A4F;
      color: white;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
    }
    QStatusBar::item {
      border: none;
    }
    QStatusBar QLabel {
      color: white;
      padding: 0 8px;
    }

    /* ── Navigation Dock ── */
    QDockWidget {
      background-color: #F3F3F3;
      border-right: 1px solid #B7E4C7;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
    }
    QDockWidget::title {
      background-color: #D8F3DC;
      padding: 6px 10px;
      border-bottom: 1px solid #B7E4C7;
      font-weight: bold;
      color: #1D6B2B;
    }
    QDockWidget::close-button, QDockWidget::float-button {
      border: none;
      background: transparent;
      padding: 2px;
    }

    /* ── Combo Boxes ── */
    QComboBox {
      border: 1px solid #95D5B2;
      border-radius: 3px;
      padding: 2px 6px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
      height: 24px;
      background: #FFFFFF;
      color: #1F3D2B;
    }
    QComboBox:hover {
      border-color: #52B788;
    }
    QComboBox:focus {
      border-color: #2D6A4F;
    }
    QComboBox::drop-down {
      border-left: 1px solid #95D5B2;
      width: 18px;
    }
    QComboBox QAbstractItemView {
      border: 1px solid #95D5B2;
      background: #FFFFFF;
      selection-background-color: #D8F3DC;
      selection-color: #1D6B2B;
    }

    /* ── QFontComboBox ── */
    QFontComboBox {
      border: 1px solid #95D5B2;
      border-radius: 3px;
      padding: 2px 6px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
      height: 24px;
      background: #FFFFFF;
      color: #1F3D2B;
    }
    QFontComboBox:hover {
      border-color: #52B788;
    }
    QFontComboBox:focus {
      border-color: #2D6A4F;
    }
    QFontComboBox::drop-down {
      border-left: 1px solid #95D5B2;
      width: 18px;
    }
    QFontComboBox QAbstractItemView {
      border: 1px solid #95D5B2;
      background: #FFFFFF;
      selection-background-color: #D8F3DC;
      selection-color: #1D6B2B;
    }

    /* ── Line Edit ── */
    QLineEdit {
      border: 1px solid #95D5B2;
      border-radius: 3px;
      padding: 3px 8px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      background: #FFFFFF;
      color: #1F3D2B;
    }
    QLineEdit:hover {
      border-color: #52B788;
    }
    QLineEdit:focus {
      border-color: #2D6A4F;
    }

    /* ── Scroll Areas ── */
    QScrollArea {
      background-color: #C0C0C0;
      border: none;
    }
    QScrollBar:vertical {
      background: #F0F0F0;
      width: 14px;
      margin: 0;
    }
    QScrollBar::handle:vertical {
      background: #95D5B2;
      border-radius: 4px;
      min-height: 30px;
      margin: 2px 2px;
    }
    QScrollBar::handle:vertical:hover {
      background: #52B788;
    }
    QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
      height: 0;
    }
    QScrollBar:horizontal {
      background: #F0F0F0;
      height: 14px;
      margin: 0;
    }
    QScrollBar::handle:horizontal {
      background: #95D5B2;
      border-radius: 4px;
      min-width: 30px;
      margin: 2px 2px;
    }
    QScrollBar::handle:horizontal:hover {
      background: #52B788;
    }
    QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
      width: 0;
    }

    /* ── Tree Widget ── */
    QTreeWidget {
      border: none;
      background: transparent;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      outline: none;
    }
    QTreeWidget::item {
      padding: 5px 6px;
      border-radius: 3px;
    }
    QTreeWidget::item:hover {
      background-color: #D8F3DC;
    }
    QTreeWidget::item:selected {
      background-color: #B7E4C7;
      color: #1D6B2B;
    }

    /* ── Tab Bar ── */
    QTabBar::tab {
      background: #FFFFFF;
      border: none;
      border-bottom: 2px solid transparent;
      padding: 6px 16px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      color: #555555;
      min-width: 60px;
    }
    QTabBar::tab:hover {
      background: #F0FFF4;
      color: #2D6A4F;
    }
    QTabBar::tab:selected {
      color: #2D6A4F;
      border-bottom: 2px solid #2D6A4F;
      font-weight: bold;
    }
    QTabWidget::pane {
      border-top: 1px solid #B7E4C7;
      background: #FFFFFF;
    }

    /* ── Splitter ── */
    QSplitter::handle {
      background-color: #B7E4C7;
      width: 1px;
    }

    /* ── Label ── */
    QLabel {
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      color: #1F3D2B;
    }

    /* ── Push Buttons ── */
    QPushButton {
      background: transparent;
      border: 1px solid transparent;
      border-radius: 3px;
      padding: 4px 10px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
      color: #1F3D2B;
    }
    QPushButton:hover {
      background-color: #D8F3DC;
      border-color: #95D5B2;
    }
    QPushButton:pressed {
      background-color: #B7E4C7;
    }
   </string>
