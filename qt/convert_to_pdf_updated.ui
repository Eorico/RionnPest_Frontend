  <widget class="QToolBar" name="quickAccessToolBar">
   <property name="windowTitle">
    <string>Quick Access Toolbar</string>
   </property>
   <property name="styleSheet">
    <string notr="true">
     QToolBar {
       background-color: #2D6A4F;
       border-bottom: 1px solid #1F4D2C;
       padding: 2px 8px;
       spacing: 2px;
     }
     QToolButton {
       background: transparent;
       border: 1px solid transparent;
       border-radius: 3px;
       padding: 2px 6px;
       color: #FFFFFF;
       font-size: 11px;
     }
     QToolButton:hover {
       background-color: rgba(255,255,255,0.2);
       border-color: rgba(255,255,255,0.4);
     }
     QToolButton:pressed {
       background-color: rgba(0,0,0,0.2);
     }
     QToolBar::separator {
       width: 1px;
       background-color: rgba(255,255,255,0.3);
       margin: 3px 4px;
     }
    </string>
   </property>
   <property name="movable">
    <bool>false</bool>
   </property>
   <property name="iconSize">
    <size>
     <width>16</width>
     <height>16</height>
    </size>
   </property>
   <attribute name="toolBarArea">
    <enum>TopToolBarArea</enum>
   </attribute>
   <attribute name="toolBarBreak">
    <bool>false</bool>
   </attribute>
   <addaction name="actionNew"/>
   <addaction name="actionSave"/>
   <addaction name="actionUndo"/>
   <addaction name="actionRedo"/>
   <addaction name="separator"/>
   <addaction name="actionExport_PDF"/>
   <addaction name="separator"/>
   <addaction name="actionFind"/>
   <addaction name="actionReplace"/>
   <addaction name="actionSelect_All"/>
  </widget>
  <widget class="QToolBar" name="ribbonToolBar">
   <property name="windowTitle">
    <string>Ribbon</string>
   </property>
   <property name="styleSheet">
    <string notr="true">
     QToolBar {
       background-color: #F0FFF4;
       border-bottom: 2px solid #B7E4C7;
       padding: 4px 10px;
       spacing: 4px;
     }
     QToolBar::separator {
       width: 1px;
       background-color: #B7E4C7;
       margin: 3px 6px;
     }
     QToolButton {
       background: transparent;
       border: 1px solid transparent;
       border-radius: 3px;
       padding: 3px 7px;
       color: #1F3D2B;
       font-size: 11px;
       min-width: 28px;
     }
     QToolButton:hover {
       background-color: #D8F3DC;
       border-color: #95D5B2;
     }
     QToolButton:pressed {
       background-color: #B7E4C7;
     }
     QToolButton:checked {
       background-color: #D8F3DC;
       border-color: #52B788;
       color: #1D6B2B;
       font-weight: bold;
     }
    </string>
   </property>
   <property name="movable">
    <bool>false</bool>
   </property>
   <property name="iconSize">
    <size>
     <width>20</width>
     <height>20</height>
    </size>
   </property>
   <property name="toolButtonStyle">
    <enum>Qt::ToolButtonTextBesideIcon</enum>
   </property>
   <attribute name="toolBarArea">
    <enum>TopToolBarArea</enum>
   </attribute>
   <attribute name="toolBarBreak">
    <bool>true</bool>
   </attribute>
