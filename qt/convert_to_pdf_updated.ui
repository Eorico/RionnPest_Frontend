<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1600</width>
    <height>1000</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>1280</width>
    <height>800</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>Document1 — Word</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: #C0C0C0; }

    /* ── Menu Bar ── */
    QMenuBar {
      background-color: #1D6B2B;
      color: white;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      spacing: 0px;
    }
    QMenuBar::item {
      background: transparent;
      padding: 7px 14px;
    }
    QMenuBar::item:selected {
      background-color: rgba(255,255,255,0.18);
    }
    QMenuBar::item:pressed {
      background-color: #FFFFFF;
      color: #1D6B2B;
      font-weight: bold;
    }

    /* ── Drop-down Menus ── */
    QMenu {
      background-color: #FFFFFF;
      border: 1px solid #C8C8C8;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
    }
    QMenu::item {
      padding: 7px 28px 7px 20px;
      color: #2C2C2C;
    }
    QMenu::item:selected {
      background-color: #F0F7F1;
      color: #1D6B2B;
    }
    QMenu::separator {
      height: 1px;
      background: #E0E0E0;
      margin: 3px 0;
    }
    QMenu::icon {
      padding-left: 6px;
    }

    /* ── Ribbon / Toolbar ── */
    QToolBar {
      background-color: #FFFFFF;
      border-bottom: 1px solid #C5DFC9;
      padding: 6px 10px;
      spacing: 4px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    }
    QToolBar::separator {
      width: 1px;
      background-color: #D8D8D8;
      margin: 4px 6px;
    }
    QToolButton {
      background: transparent;
      border: 1px solid transparent;
      border-radius: 3px;
      padding: 4px 8px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
      color: #2C2C2C;
      min-width: 32px;
    }
    QToolButton:hover {
      background-color: #F0F7F1;
      border-color: #C5DFC9;
    }
    QToolButton:pressed {
      background-color: #C5DFC9;
    }
    QToolButton:checked {
      background-color: #F0F7F1;
      border-color: #C5DFC9;
      color: #1D6B2B;
    }

    /* ── Document Text Area ── */
    QTextEdit {
      background-color: #FFFFFF;
      border: none;
      font-family: &quot;Calibri&quot;, Georgia, serif;
      font-size: 15px;
      color: #111111;
      line-height: 1.8;
    }

    /* ── Status Bar ── */
    QStatusBar {
      background-color: #1D6B2B;
      color: white;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
    }
    QStatusBar::item {
      border: none;
    }

    /* ── Navigation Dock ── */
    QDockWidget {
      background-color: #F3F3F3;
      border-right: 1px solid #C8C8C8;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      titlebar-close-icon: url(none);
    }
    QDockWidget::title {
      background-color: #E8E8E8;
      padding: 6px 10px;
      border-bottom: 1px solid #C8C8C8;
      font-weight: bold;
      color: #333333;
    }
    QDockWidget::close-button, QDockWidget::float-button {
      border: none;
      background: transparent;
      padding: 2px;
    }

    /* ── Combo Boxes ── */
    QComboBox {
      border: 1px solid #C8C8C8;
      border-radius: 3px;
      padding: 2px 6px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
      height: 24px;
      min-width: 90px;
      background: #FFFFFF;
      color: #2C2C2C;
    }
    QComboBox:hover {
      border-color: #B0CEB4;
    }
    QComboBox:focus {
      border-color: #2E8B3F;
    }
    QComboBox::drop-down {
      border-left: 1px solid #C8C8C8;
      width: 18px;
    }
    QComboBox QAbstractItemView {
      border: 1px solid #C8C8C8;
      background: #FFFFFF;
      selection-background-color: #F0F7F1;
      selection-color: #1D6B2B;
    }

    /* ── Line Edit (search box, font size) ── */
    QLineEdit {
      border: 1px solid #C8C8C8;
      border-radius: 3px;
      padding: 3px 8px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      background: #FFFFFF;
      color: #2C2C2C;
    }
    QLineEdit:hover {
      border-color: #B0CEB4;
    }
    QLineEdit:focus {
      border-color: #2E8B3F;
    }

    /* ── Scroll Areas ── */
    QScrollArea {
      background-color: #C0C0C0;
      border: none;
    }
    QScrollBar:vertical {
      background: #F0F0F0;
      width: 14px;
      margin: 0;
    }
    QScrollBar::handle:vertical {
      background: #B0B0B0;
      border-radius: 4px;
      min-height: 30px;
      margin: 2px 2px;
    }
    QScrollBar::handle:vertical:hover {
      background: #888888;
    }
    QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
      height: 0;
    }
    QScrollBar:horizontal {
      background: #F0F0F0;
      height: 14px;
      margin: 0;
    }
    QScrollBar::handle:horizontal {
      background: #B0B0B0;
      border-radius: 4px;
      min-width: 30px;
      margin: 2px 2px;
    }
    QScrollBar::handle:horizontal:hover {
      background: #888888;
    }
    QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
      width: 0;
    }

    /* ── Tree Widget (Navigation headings) ── */
    QTreeWidget {
      border: none;
      background: transparent;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      outline: none;
    }
    QTreeWidget::item {
      padding: 5px 6px;
      border-radius: 3px;
    }
    QTreeWidget::item:hover {
      background-color: #F0F7F1;
    }
    QTreeWidget::item:selected {
      background-color: #E2F0E4;
      color: #1D6B2B;
    }

    /* ── Tab Bar (ribbon tabs) ── */
    QTabBar::tab {
      background: #FFFFFF;
      border: none;
      border-bottom: 2px solid transparent;
      padding: 6px 16px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 12px;
      color: #555555;
      min-width: 60px;
    }
    QTabBar::tab:hover {
      background: #F5F5F5;
      color: #1D6B2B;
    }
    QTabBar::tab:selected {
      color: #1D6B2B;
      border-bottom: 2px solid #1D6B2B;
      font-weight: bold;
    }
    QTabWidget::pane {
      border-top: 1px solid #D0D0D0;
      background: #FFFFFF;
    }

    /* ── Splitter ── */
    QSplitter::handle {
      background-color: #C8C8C8;
      width: 1px;
    }

    /* ── Label ── */
    QLabel {
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      color: #333333;
    }

    /* ── Push Buttons (ribbon group buttons) ── */
    QPushButton {
      background: transparent;
      border: 1px solid transparent;
      border-radius: 3px;
      padding: 4px 10px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
      font-size: 11px;
      color: #2C2C2C;
    }
    QPushButton:hover {
      background-color: #F0F7F1;
      border-color: #C5DFC9;
    }
    QPushButton:pressed {
      background-color: #C5DFC9;
    }
   </string>
  </property>
